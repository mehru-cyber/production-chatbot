# --- Required ---
OPENAI_API_KEY=sk-...
DATABASE_URL=postgresql://postgres:postgres@localhost:5442/postgres
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# --- Recommended (real stock prices; without it, tool returns a clear error) ---
FINNHUB_API_KEY=

# --- Optional (enables real paper-trading execution; without it, purchase_stock
#     returns a clearly labeled simulated response) ---
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Optional observability (tracing dashboard at cloud.langfuse.com) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App tuning ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
RATE_LIMIT_PER_MINUTE=20
DAILY_TOKEN_CAP=200000
STM_TRIM_MESSAGE_THRESHOLD=6
STM_KEEP_LAST_N=2
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5500
